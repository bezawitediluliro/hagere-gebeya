# Database
DATABASE_URL="file:./dev.db"

# Telegram Bot
BOT_TOKEN="your_bot_token_here"
ADMIN_TELEGRAM_IDS="123456789,987654321"

# Server
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET="your_super_secret_jwt_key_change_this"

# Mini App URL (your deployed frontend URL)
MINI_APP_URL="https://your-frontend.vercel.app"

# TeleBirr (future integration)
TELEBIRR_APP_ID=""
TELEBIRR_APP_KEY=""
TELEBIRR_SHORT_CODE=""
TELEBIRR_PUBLIC_KEY=""
TELEBIRR_NOTIFY_URL=""

# File uploads (optional - use local or S3)
UPLOAD_DIR="./uploads"
